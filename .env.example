# Server Configuration
PORT=8500
NODE_ENV=production

# Source Odoo
ODOO_SOURCE_HOST=https://your-source-odoo.com
ODOO_SOURCE_DB=source_db_name
ODOO_SOURCE_USERNAME=admin@source.com
ODOO_SOURCE_API_KEY=your_api_key

# Destination Odoo
ODOO_DEST_URL=http://localhost:1800
ODOO_DEST_DB=dest_db_name
ODOO_DEST_USERNAME=admin
ODOO_DEST_API_KEY=your_dest_api_key

# Redis (required for BullMQ queue)
REDIS_URL=redis://localhost:6379

# API Basic Auth (used by login endpoint and middleware)
API_USERNAME=admin
API_PASSWORD=choose_a_strong_password

# Migration
MAX_FILE_SIZE_MB=50
